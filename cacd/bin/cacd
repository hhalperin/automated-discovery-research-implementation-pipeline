#!/usr/bin/env bash
# cacd — universal Continuous-Agent Continuous-Development CLI.
#
# Usage:
#   cacd init [--force]              Install CACD into current repo.
#   cacd new-repo <name> [--language=py|node|generic] [--owner=<gh-owner>]
#                                    Scaffold a brand-new repo with CACD.
#   cacd run [--check=<name>] [--judge=<name>]
#                                    Run all gates + judges and write JSON + report.
#   cacd check <name>                Run a single deterministic check.
#   cacd judge <name>                Run a single LLM judge.
#   cacd report                      Aggregate .cacd/out into report.md.
#   cacd cleanup-branches            Prune merged branches, label stale PRs.
#   cacd revert <sha>                Open a revert PR for a merged commit.
#   cacd version                     Print the CACD version.

set -euo pipefail

CACD_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CACD_ROOT
VERSION_FILE="$CACD_ROOT/VERSION"
CACD_VERSION=$(cat "$VERSION_FILE" 2>/dev/null || echo "0.0.0")

usage() { sed -n '3,20p' "$0" | sed 's/^# \{0,1\}//'; }

cmd="${1:-}"
[[ $# -gt 0 ]] && shift || true

case "$cmd" in
    ""|-h|--help|help) usage ;;
    version|--version) echo "cacd $CACD_VERSION" ;;

    init)
        exec "$CACD_ROOT/install.sh" "$PWD" "$@"
        ;;

    new-repo)
        exec "$CACD_ROOT/lib/new-repo.sh" "$@"
        ;;

    run)
        exec "$CACD_ROOT/lib/run.sh" "$@"
        ;;

    check)
        name="${1:?check name required}"; shift || true
        script="$CACD_ROOT/lib/checks/$name.sh"
        [[ -x "$script" ]] || { echo "no such check: $name" >&2; exit 2; }
        exec "$script" "$@"
        ;;

    judge)
        name="${1:?judge name required}"; shift || true
        script="$CACD_ROOT/lib/judges/$name.sh"
        [[ -x "$script" ]] || { echo "no such judge: $name" >&2; exit 2; }
        exec "$script" "$@"
        ;;

    report)
        exec "$CACD_ROOT/lib/report.sh" "$@"
        ;;

    cleanup-branches)
        exec "$CACD_ROOT/lib/branch-cleanup.sh" "$@"
        ;;

    revert)
        exec "$CACD_ROOT/lib/revert.sh" "$@"
        ;;

    *)
        echo "unknown subcommand: $cmd" >&2
        usage
        exit 2
        ;;
esac
