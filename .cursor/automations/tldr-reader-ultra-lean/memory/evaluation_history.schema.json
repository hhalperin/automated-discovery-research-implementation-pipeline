{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "evaluation_history",
  "description": "Learning from past runs: why selected/rejected, false positives, patterns to suppress",
  "type": "object",
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "item": { "type": "string" },
          "outcome": { "type": "string", "enum": ["selected", "rejected", "false_positive"] },
          "reason": { "type": "string" }
        }
      }
    },
    "suppress_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Categories/source types that repeatedly waste time"
    },
    "routing_mistakes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": { "type": "string" },
          "wrong_repo": { "type": "string" },
          "correct_repo": { "type": "string" }
        }
      }
    }
  }
}
