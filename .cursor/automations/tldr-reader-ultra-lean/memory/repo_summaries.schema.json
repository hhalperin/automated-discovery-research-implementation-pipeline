{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "repo_summaries",
  "description": "~200-token summary per repo for relevance scanning",
  "type": "object",
  "properties": {
    "summaries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string", "maxLength": 400 },
          "what_it_does": { "type": "string" },
          "core_architecture": { "type": "string" },
          "current_priorities": { "type": "array", "items": { "type": "string" } },
          "integration_surfaces": { "type": "array", "items": { "type": "string" } },
          "does_not_belong": { "type": "string" }
        }
      }
    }
  }
}
