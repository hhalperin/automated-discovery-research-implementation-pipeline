{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "routing_rules",
  "description": "Rules for mapping TLDR ideas to repos",
  "type": "object",
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "target_repo"],
        "properties": {
          "pattern": { "type": "string", "description": "Keywords/themes: orchestration, agents, evals, infra, ML, etc." },
          "target_repo": { "type": "string" },
          "priority": { "type": "string", "enum": ["primary", "secondary", "deprioritize"] }
        }
      }
    }
  }
}
